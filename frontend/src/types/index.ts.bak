// Tipos de Vehiculo
export interface Vehiculo {
  id: number;
  codigo: string;
  matricula: string;
  marca: string;
  modelo: string;
  annoFabricacion?: number;
  plazas: number;
  tipo: 'minibus' | 'bus' | 'furgoneta' | 'coche';
  estado: 'activo' | 'inactivo' | 'taller' | 'baja';
  itv?: {
    fechaUltima: string;
    fechaProxima: string;
    resultado: 'favorable' | 'desfavorable' | 'negativo';
  };
  seguro?: {
    compania: string;
    poliza: string;
    fechaVencimiento: string;
  };
  imagenUrl?: string;
  fechaAlta: string;
  notas?: string;
  activo?: boolean;
  contacto?: {
    nombre: string;
    email?: string;
    telefono?: string;
    cargo?: string;
  };
}

